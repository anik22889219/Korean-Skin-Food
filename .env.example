# ══════════════════════════════════════════════
# KOREAN SKIN FOOD — ENV TEMPLATE
# Copy this file to .env and fill in your values
# ══════════════════════════════════════════════

# ── Backend API ──────────────────────────────
VITE_APPS_SCRIPT_URL=https://script.google.com/macros/s/YOUR_SCRIPT_ID/exec

# ── AI ───────────────────────────────────────
VITE_GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here

# ── WhatsApp ─────────────────────────────────
# Format: 8801XXXXXXXXX (no + sign, no spaces)
VITE_WHATSAPP_NUMBER=8801755837545

# ── Analytics & Tracking ─────────────────────
VITE_META_PIXEL_ID=your_meta_pixel_id
VITE_GA_ID=G-XXXXXXXXXX
VITE_TIKTOK_PIXEL_ID=your_tiktok_pixel_id

# ── CDN ──────────────────────────────────────
VITE_CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name

# ── Social ───────────────────────────────────
VITE_FACEBOOK_URL=https://www.facebook.com/your_page
VITE_INSTAGRAM_URL=https://www.instagram.com/your_handle

# ── Site ─────────────────────────────────────
VITE_SITE_URL=https://koreanskinfood.com
VITE_SITE_NAME=Korean Skin Food
